# ──────────────────────────────────────────────────────────────────────
# CAREERPILOT ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and configure keys to run CareerPilot locally.
# ──────────────────────────────────────────────────────────────────────

# ── JSearch API (openwebninja - Primary for Bangladesh) ─────────────────
# JSearch supports Bangladesh and global job search via openwebninja.com
# Sign up at: https://openwebninja.com (Free tier available)
JSEARCH_API_KEY=your_jsearch_api_key

# ── Adzuna API (Fallback for JSearch) ────────────────────────────────────
# Only supports: gb, us, au, ca, de, fr, it, nl, nz, sg, za
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Supabase Database Credentials ─────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Pinecone Vector Database ──────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=careerpilot-cv
PINECONE_ENV=your_pinecone_environment_region
EMBED_DIM=768

# ── Large Language Model API Keys ─────────────────────────────────────
# (Provide at least one of the keys below)
# Groq (Recommended - Fast & Free): https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# NVIDIA NIM (High Quality): https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key

# ── Clerk Authentication ──────────────────────────────────────────────
CLERK_JWKS_URL=your_clerk_jwks_url
CLERK_ISSUER=your_clerk_issuer_url
CLERK_AUDIENCE=your_clerk_audience
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# ── Error Tracking (Sentry) ──────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── SSL / Domain (nginx + certbot) ────────────────────────────────────
DOMAIN=careerpilot.example.com
SSL_EMAIL=admin@example.com

# ── Settings Admin Key (required for POST /api/settings) ──────────────
SETTINGS_ADMIN_KEY=your_admin_key_here

# ── Monitoring ────────────────────────────────────────────────────────
GRAFANA_PASSWORD=your_grafana_password_here

# ── Production Settings ───────────────────────────────────────────────
ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=60
REDIS_URL=redis://localhost:6379/0

# ── Dev Auth ──────────────────────────────────────────────────────────
# Set to "true" to enable demo user when no token is provided (dev only)
DEV_DEMO_USER_ENABLED=false
