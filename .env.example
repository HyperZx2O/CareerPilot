# ──────────────────────────────────────────────────────────────────────
# CAREERPILOT ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and configure keys to run CareerPilot locally.
# ──────────────────────────────────────────────────────────────────────

# ── Adzuna Job Vacancy Search API ─────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Supabase Database Credentials ─────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_public_key

# ── Pinecone Vector Database ──────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=careerpilot-cv
PINECONE_ENV=your_pinecone_environment_region

# ── Large Language Model API Keys ─────────────────────────────────────
# (Provide at least one of the keys below)
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
