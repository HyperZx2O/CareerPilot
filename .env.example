# CareerPilot Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── OpenAI (primary LLM fallback + embeddings) ─────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google Gemini (primary LLM) ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Pinecone (vector store) ─────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=careerpilot
PINECONE_ENV=us-east-1

# ── Supabase (PostgreSQL) ───────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ── Clerk (JWT authentication) ──────────────────────────────────────────────
# Set ONE of the following:
#   CLERK_JWT_PUBLIC_KEY  — paste the PEM public key from Clerk dashboard
#   CLERK_JWKS_URL        — e.g. https://<your-clerk-domain>/.well-known/jwks.json
# If neither is set the server runs in test mode (accepts any Bearer token).
CLERK_JWT_PUBLIC_KEY=
CLERK_JWKS_URL=

# ── JSearch (live job listings via RapidAPI) ────────────────────────────────
JSEARCH_API_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
