# ==============================================================================
# CareerPilot frontend - environment template
# Copy this file to frontend/.env.local and fill in the values.
# frontend/.env.local is in .gitignore and will NOT be committed.
# ==============================================================================

# Backend API URL. In dev this is the local FastAPI server on :8000.
# In production set this to your deployed backend (e.g. https://api.example.com).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk publishable key (BROWSER-SAFE - safe to expose).
# Get it from https://dashboard.clerk.com -> API Keys -> Publishable key.
# Format: pk_test_...$  (or pk_live_...$ in production) - MUST end with $.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_ending_in_dollar

# Clerk secret key (SERVER-SIDE - never expose to the browser).
# Only used by Next.js server actions / route handlers that call the Clerk SDK
# directly. The backend FastAPI uses CLERK_SECRET_KEY from the root .env instead.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
