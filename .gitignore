# ==============================================================================
# CareerPilot - .gitignore
# Tuned to the actual files in this repo (Python/FastAPI backend + Next.js
# frontend).  Stale tooling stubs (Scrapy, SageMath, PyInstaller, Flask, Django,
# pipenv/poetry/pdm, Jupyter, mkdocs) have been removed.
# ==============================================================================

# --- System & OS files ---
.DS_Store
.DS_Store?
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDEs & Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- AI agent / tooling caches ---
.claude/
.puku/
.opencode/
.repowise/
.dual-graph/
.understand-anything/
.gemini/

# ==============================================================================
# Backend (Python / FastAPI)
# ==============================================================================

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/

# Unit testing / coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.tox/
.cache

# Environments
.env
.env.local
.env.*.local
.venv/
venv/
env/
ENV/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# Celery (this project uses Celery workers)
celerybeat-schedule
celerybeat.pid

# Project-specific backend artefacts
backend/uploads/
backend/*.db
backend/*.sqlite
server.err

# ==============================================================================
# Frontend (Node / Next.js)
# ==============================================================================

# Dependencies
node_modules/
frontend/node_modules/

# Next.js build output
.next/
frontend/.next/
frontend/out/
out/

# Production build output
build/
frontend/build/

# Next.js debug / telemetry logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# Next.js types and cache
frontend/.next/cache/
frontend/next-env.d.ts.bak
frontend/.swc/

# Frontend environment files
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# ==============================================================================
# Project-wide
# ==============================================================================

# Logs
*.log
logs/

# Temp / working directories
tmp/
temp/
*.tmp

# Deployment configs (may contain secrets)
.vercel/
.netlify/
.railway/

# Temporary test / scratch files
tmp_test.py
check_keys.py
test_*.py
frontend/tmp_test.py
frontend/check_keys.py
frontend/test_*.py

# AI agent docs (tracked in repo root for agent context, ignored elsewhere)
**/CLAUDE.md
**/CONTEXT.md

# Nixpacks not needed if not deploying on Render
nixpacks.toml

# OS metadata
*~

# Allow specific files even if a parent pattern matches
!frontend/.env.example
!backend/.env.example
